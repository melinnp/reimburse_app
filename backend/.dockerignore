.git
.gitignore
.gitattributes
.editorconfig
.hintrc
.prettierrc

# Dev dependencies never go in the image
node_modules/
vendor/

# Tests & CI
tests/
phpunit.xml

# Local env files — never bake secrets into the image
.env
.env.backup

# Logs
storage/logs/
*.log

# Runtime cache — will be regenerated by entrypoint
bootstrap/cache/*.php
storage/framework/cache/
storage/framework/sessions/
storage/framework/views/

# Docs
README.md
REFACTORING_REPORT.md
docs/

